{
  "name": "swoosh",
  "private": true,
  "version": "0.0.1",
  "description": "Hand-tracked system control for Windows, macOS, and Linux.",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm --filter swoosh-desktop dev",
    "build": "pnpm --filter swoosh-desktop build",
    "test": "pnpm -r --if-present test",
    "test:e2e": "pnpm --filter swoosh-desktop test:e2e",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "package": "pnpm --filter swoosh-desktop package",
    "package:all": "pnpm --filter swoosh-desktop package:all"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
