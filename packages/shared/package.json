{
  "name": "@swoosh/shared",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./ipc": {
      "types": "./src/ipc.ts",
      "import": "./src/ipc.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./src/types.ts"
    },
    "./gesture/*": {
      "types": "./src/gesture/*.ts",
      "import": "./src/gesture/*.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "vitest": "^2.1.5",
    "@types/node": "^22.9.0"
  }
}
