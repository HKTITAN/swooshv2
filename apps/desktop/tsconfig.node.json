{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "lib": ["ES2022"],
    "types": ["node", "electron-vite/node"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "./dist/node"
  },
  "include": [
    "src/main/**/*",
    "src/preload/**/*",
    "electron.vite.config.ts",
    "electron-builder.yml"
  ]
}
